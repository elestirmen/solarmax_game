{
  "name": "stellar-conquest",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "server": "node server.js",
    "build": "vite build",
    "deploy": "bash ./scripts/deploy.sh docker",
    "deploy:docker": "bash ./scripts/deploy.sh docker",
    "deploy:local": "bash ./scripts/deploy.sh local",
    "deploy:check": "bash ./scripts/deploy.sh check",
    "preview": "vite preview",
    "test": "node --test",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:docker": "docker run --rm --network host --ipc=host -v \"$(pwd)\":/work -v /work/node_modules -v /work/dist -v /work/test-results -v /work/playwright-report -w /work mcr.microsoft.com/playwright:v1.58.2-jammy bash -lc \"npm ci && npm run e2e\""
  },
  "dependencies": {
    "express": "^4.21.2",
    "socket.io": "^4.8.1"
  },
  "overrides": {
    "path-to-regexp": "0.1.13",
    "socket.io-parser": "4.2.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "vite": "6.4.2"
  }
}
